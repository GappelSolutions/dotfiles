#!/bin/sh
# Update CodeLayer nightly via Homebrew
# Runs weekly via launchd agent

set -e

LOG="/tmp/codelayer-update.log"
BREW="/opt/homebrew/bin/brew"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG"; }

log "Starting CodeLayer nightly update"

# Quit app if running
osascript -e 'tell application "CodeLayer-Nightly" to quit' 2>/dev/null || true
sleep 2

# Update brew tap and upgrade cask
$BREW update --quiet 2>>"$LOG"
OUTPUT=$($BREW upgrade --cask humanlayer/humanlayer/codelayer-nightly 2>&1) || true

if echo "$OUTPUT" | grep -q "already installed"; then
  log "Already up to date"
else
  log "Upgrade output: $OUTPUT"
fi

# Remove quarantine flag (Gatekeeper) — cask upgrades reapply it
xattr -rd com.apple.quarantine /Applications/CodeLayer-Nightly.app 2>/dev/null || true
log "Update complete"
