#!/bin/bash
# Opens a file in Obsidian using the URI scheme.
# Falls back to system `open` for non-vault files.

VAULT_DIR="$HOME/dev/codelayer-vault"
VAULT_NAME="codelayer-vault"

filepath="$(realpath "$1" 2>/dev/null || echo "$1")"

if [[ "$filepath" == "$VAULT_DIR"/* ]]; then
  relative="${filepath#$VAULT_DIR/}"
  open "obsidian://open?vault=$VAULT_NAME&file=$relative"
else
  open "$filepath"
fi
